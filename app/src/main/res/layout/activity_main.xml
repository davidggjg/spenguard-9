<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#0D1117"
    android:layoutDirection="rtl">

    <TextView
        android:id="@+id/statusIcon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="!"
        android:textSize="72sp"
        android:textColor="#FF6B6B"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SPenGuard"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#00E5FF"
        android:layout_marginBottom="6dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="הגנה אוטומטית לשליפת S Pen"
        android:textSize="13sp"
        android:textColor="#8B949E"
        android:layout_marginBottom="36dp" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="#161B22"
        app:cardElevation="6dp"
        android:layout_marginBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center">

            <TextView
                android:id="@+id/statusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="לחץ כדי להפעיל את ההגנה"
                android:textSize="15sp"
                android:textColor="#E6EDF3"
                android:gravity="center"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="20dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layoutDirection="rtl">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="הגנה פעילה"
                    android:textColor="#E6EDF3"
                    android:textSize="15sp"
                    android:layout_marginEnd="12dp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/guardSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="#161B22"
        app:cardElevation="4dp"
        android:layout_marginBottom="28dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="מצלם עם המצלמה הקדמית"
                android:textColor="#C9D1D9"
                android:textSize="14sp"
                android:layout_marginBottom="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="מצפצף 5 שניות מעל שקט ורטט"
                android:textColor="#C9D1D9"
                android:textSize="14sp"
                android:layout_marginBottom="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="עובד גם עם מסך כבוי"
                android:textColor="#C9D1D9"
                android:textSize="14sp"
                android:layout_marginBottom="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="שומר תמונה לגלריה אוטומטית"
                android:textColor="#C9D1D9"
                android:textSize="14sp"
                android:layout_marginBottom="10dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="מתחיל אוטומטי אחרי ריסטארט"
                android:textColor="#C9D1D9"
                android:textSize="14sp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <Button
        android:id="@+id/startButton"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="הפעל הגנה"
        android:textSize="17sp"
        android:textColor="#0D1117"
        android:backgroundTint="#00E5FF" />

</LinearLayout>
